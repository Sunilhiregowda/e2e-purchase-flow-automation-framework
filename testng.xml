<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">
<suite name="SauceDemo E2E Suite" parallel="tests" thread-count="3">

	<listeners>
		<listener class-name="com.framework.listeners.TestListener" />
		<listener class-name="com.framework.listeners.ReportListener" />
	</listeners>

	<test name="Chrome Execution">
		<parameter name="browser" value="chrome" />
		<classes>
			<class name="com.tests.PurchaseFlowTest" />
		</classes>
	</test>

	<test name="Edge Execution">
		<parameter name="browser" value="edge" />
		<classes>
			<class name="com.tests.PurchaseFlowTest" />
		</classes>
	</test>

	<test name="Firefox Execution">
		<parameter name="browser" value="firefox" />
		<classes>
			<class name="com.tests.PurchaseFlowTest" />
		</classes>
	</test>

</suite>